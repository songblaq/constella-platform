    "~/.constellar/profiles/ops.json",
    "~/.constellar/backups/nas-backup-manifest.json"
  ],
  "runtime_family": [
    "openclaw",
    "claude-code",
    "codex",
    "opencode",
    "cursor",
    "copilot"
  ]
}
