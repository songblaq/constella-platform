{
  "version": "2026-03-26",
  "name": "constella-bootstrap-bundle",
  "install_modes": [
    "bootstrap",
    "dev",
    "runtime-only",
    "ops"
  ],
  "required_artifacts": [
    "~/.constellar/manifests/repo-classes.json",
    "~/.constellar/manifests/migration-matrix.json",
    "~/.constellar/manifests/compatibility-shims.json",
    "~/.constellar/profiles/bootstrap.json",
    "~/.constellar/profiles/dev.json",
